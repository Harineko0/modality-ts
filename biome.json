{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "includes": [
      "**",
      "!dist",
      "!examples",
      "!.modality",
      "!native/index.js",
      "!node_modules",
      "!docs/node_modules",
      "!docs/build",
      "!docs/.docusaurus"
    ]
  },
  "formatter": {
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        }
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  }
}
