{
  "name": "@modality-ts/source-router",
  "version": "0.0.0",
  "description": "React Router source plugin for modality extraction and replay.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harineko0/modality-ts.git",
    "directory": "packages/sources/router"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./harness": {
      "types": "./dist/harness.d.ts",
      "default": "./dist/harness.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b"
  },
  "peerDependencies": {
    "react-router": ">=6",
    "react-router-dom": ">=6"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@modality-ts/extraction": "workspace:*",
    "@modality-ts/kernel": "workspace:*"
  }
}
