{
  "schemaVersion": 1,
  "manifestId": "repo-canaries",
  "canaries": [
    {
      "id": "examples-demo-app",
      "title": "Demo app seeded-bug acceptance",
      "status": "active",
      "kind": "react-app",
      "root": "examples/demo-app",
      "packageManager": "pnpm",
      "dependencyFacts": [
        {
          "packageName": "jotai",
          "expectedRange": "^2.0.0",
          "source": "package-json"
        },
        {
          "packageName": "swr",
          "expectedRange": "^2.0.0",
          "source": "package-json"
        }
      ],
      "extract": {
        "sourcePaths": ["App.tsx"],
        "packageJsonPath": "package.json",
        "effectApis": ["api.placeOrder"]
      },
      "check": {
        "propsPaths": ["app.props.ts"]
      },
      "thresholds": {
        "minCoverageExactOrOverlay": 1
      },
      "budgetNotApplicableReason": "Seeded-bug demo validates violation reproduction, not state-space caps.",
      "acceptedCaveats": [
        {
          "kind": "unhandled-rejection",
          "id": "App.onClick.api.placeOrder"
        }
      ],
      "knownUnsupported": [],
      "expectations": {
        "violatedPropertyCount": 3,
        "violatedPropertyNames": [
          "noDoubleSubmit",
          "guestCannotReachAdmin",
          "guestDoesNotSeeUserCache"
        ],
        "minReproducedReplayCount": 2,
        "maxOverlayLines": 100,
        "expectedCiExitCode": 2,
        "ciOutputMustInclude": [
          "violations=3 errors=0",
          "determinism=passed",
          "source-freshness=passed"
        ]
      }
    },
    {
