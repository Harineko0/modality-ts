{
  "id": "state-local-setter-batch",
  "featureIds": [
    "state.local.setter-batching",
    "state.local.functional-updater"
  ],
  "targetIds": ["react-use-state", "core"],
  "root": "test/conformance/fixtures/state-local-setter-batch",
  "sourcePaths": ["app/App.tsx"],
  "propsPaths": ["app/app.props.ts"],
  "extract": {
    "packageJsonPath": "app/package.json"
  },
  "check": {
    "enabled": true
  },
  "conform": {
    "enabled": true,
    "walkCount": 2,
    "depth": 3,
    "seed": 1
  },
  "thresholds": {
    "minCoverageExactOrOverlay": 1,
    "minConformPassRate": 1
  },
  "budgets": {
    "maxStates": 20
  },
  "expectations": {
    "transitionIdPrefixes": [
      "App.onClick.Direct batch",
      "App.onClick.Functional batch"
    ],
    "vars": [
      {
        "id": "local:App.count",
        "scope": {
          "kind": "mount-local",
          "id": "route:/",
          "when": {
            "kind": "eq",
            "args": [
              { "kind": "read", "var": "sys:route" },
              { "kind": "lit", "value": "/" }
            ]
          }
        },
        "domainKind": "boundedInt"
      }
    ],
    "effectReadKinds": [
      {
        "transitionIdPrefix": "App.onClick.Direct batch",
        "kinds": ["readPre"]
      },
      {
        "transitionIdPrefix": "App.onClick.Functional batch",
        "kinds": ["read"]
      }
    ],
    "minStateContributorVars": 1
  }
}
