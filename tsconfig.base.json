{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "modality-ts/core": ["src/core/index.ts"],
      "modality-ts/core/props": ["src/core/props/index.ts"],
      "modality-ts/check": ["src/check/index.ts"],
      "modality-ts/extract": ["src/extract/index.ts"],
      "modality-ts/extract/engine": ["src/extract/engine/index.ts"],
      "modality-ts/extract/engine/pipeline": ["src/extract/engine/pipeline/index.ts"],
      "modality-ts/extract/engine/spi": ["src/extract/engine/spi/index.ts"],
      "modality-ts/cli/harness": ["src/cli/harness/index.ts"],
      "modality-ts/cli/runtime": ["src/cli/runtime/index.ts"],
      "modality-ts/extract/sources/jotai": ["src/extract/sources/jotai/index.ts"],
      "modality-ts/extract/sources/jotai/harness": ["src/extract/sources/jotai/harness.ts"],
      "modality-ts/extract/sources/router": ["src/extract/sources/router/index.ts"],
      "modality-ts/extract/sources/router/harness": ["src/extract/sources/router/harness.ts"],
      "modality-ts/extract/sources/swr": ["src/extract/sources/swr/index.ts"],
      "modality-ts/extract/sources/swr/harness": ["src/extract/sources/swr/harness.ts"],
      "modality-ts/extract/sources/use-state": ["src/extract/sources/use-state/index.ts"],
      "modality-ts/extract/sources/use-state/harness": ["src/extract/sources/use-state/harness.ts"]
    },
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  }
}
