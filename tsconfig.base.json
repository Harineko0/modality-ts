{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "modality-ts/kernel": ["packages/kernel/src/index.ts"],
      "modality-ts/kernel/props": ["packages/kernel/src/props/index.ts"],
      "modality-ts/checker": ["packages/checker/src/index.ts"],
      "modality-ts/extraction": ["packages/extraction/src/index.ts"],
      "modality-ts/extraction/pipeline": ["packages/extraction/src/pipeline/index.ts"],
      "modality-ts/extraction/spi": ["packages/extraction/src/spi/index.ts"],
      "modality-ts/harness": ["packages/harness/src/index.ts"],
      "modality-ts/runtime": ["packages/runtime/src/index.ts"],
      "modality-ts/source-jotai": ["packages/sources/jotai/src/index.ts"],
      "modality-ts/source-jotai/harness": ["packages/sources/jotai/src/harness.ts"],
      "modality-ts/source-router": ["packages/sources/router/src/index.ts"],
      "modality-ts/source-router/harness": ["packages/sources/router/src/harness.ts"],
      "modality-ts/source-swr": ["packages/sources/swr/src/index.ts"],
      "modality-ts/source-swr/harness": ["packages/sources/swr/src/harness.ts"],
      "modality-ts/source-use-state": ["packages/sources/use-state/src/index.ts"],
      "modality-ts/source-use-state/harness": ["packages/sources/use-state/src/harness.ts"]
    },
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  }
}
