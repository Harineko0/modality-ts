{
  "name": "modality-ts",
  "version": "0.0.13",
  "description": "Model-checking-based testing tools for React state-transition bugs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harineko0/modality-ts.git"
  },
  "type": "module",
  "types": "./dist/cli/cli.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "modality": "dist/cli/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli/cli.d.ts",
      "default": "./dist/cli/cli.js"
    },
    "./cli": {
      "types": "./dist/cli/cli.d.ts",
      "default": "./dist/cli/cli.js"
    },
    "./cli/check": {
      "types": "./dist/cli/check.d.ts",
      "default": "./dist/cli/check.js"
    },
    "./cli/ci": {
      "types": "./dist/cli/ci.d.ts",
      "default": "./dist/cli/ci.js"
    },
    "./cli/conform": {
      "types": "./dist/cli/conform.d.ts",
      "default": "./dist/cli/conform.js"
    },
    "./cli/extract": {
      "types": "./dist/cli/extract.d.ts",
      "default": "./dist/cli/extract.js"
    },
    "./cli/replay": {
      "types": "./dist/cli/replay.d.ts",
      "default": "./dist/cli/replay.js"
    },
    "./cli/export-tla": {
      "types": "./dist/cli/export-tla.d.ts",
      "default": "./dist/cli/export-tla.js"
    },
    "./cli/overlay": {
      "types": "./dist/cli/overlay.d.ts",
      "default": "./dist/cli/overlay.js"
    },
    "./cli/harness": {
      "types": "./dist/cli/harness/index.d.ts",
      "default": "./dist/cli/harness/index.js"
    },
    "./cli/runtime": {
      "types": "./dist/cli/runtime/index.d.ts",
      "default": "./dist/cli/runtime/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core/props": {
      "types": "./dist/core/props/index.d.ts",
      "default": "./dist/core/props/index.js"
    },
    "./check": {
      "types": "./dist/check/index.d.ts",
      "default": "./dist/check/index.js"
    },
    "./extract": {
      "types": "./dist/extract/index.d.ts",
      "default": "./dist/extract/index.js"
    },
    "./extract/engine": {
      "types": "./dist/extract/engine/index.d.ts",
      "default": "./dist/extract/engine/index.js"
    },
    "./extract/engine/pipeline": {
      "types": "./dist/extract/engine/pipeline/index.d.ts",
      "default": "./dist/extract/engine/pipeline/index.js"
    },
    "./extract/engine/spi": {
      "types": "./dist/extract/engine/spi/index.d.ts",
      "default": "./dist/extract/engine/spi/index.js"
    },
    "./extract/sources/jotai": {
      "types": "./dist/extract/sources/jotai/index.d.ts",
      "default": "./dist/extract/sources/jotai/index.js"
    },
    "./extract/sources/jotai/harness": {
      "types": "./dist/extract/sources/jotai/harness.d.ts",
      "default": "./dist/extract/sources/jotai/harness.js"
    },
    "./extract/sources/router": {
      "types": "./dist/extract/sources/router/index.d.ts",
      "default": "./dist/extract/sources/router/index.js"
    },
    "./extract/sources/router/harness": {
      "types": "./dist/extract/sources/router/harness.d.ts",
      "default": "./dist/extract/sources/router/harness.js"
    },
    "./extract/sources/swr": {
      "types": "./dist/extract/sources/swr/index.d.ts",
      "default": "./dist/extract/sources/swr/index.js"
    },
    "./extract/sources/swr/harness": {
      "types": "./dist/extract/sources/swr/harness.d.ts",
      "default": "./dist/extract/sources/swr/harness.js"
    },
    "./extract/sources/use-state": {
      "types": "./dist/extract/sources/use-state/index.d.ts",
      "default": "./dist/extract/sources/use-state/index.js"
    },
    "./extract/sources/use-state/harness": {
      "types": "./dist/extract/sources/use-state/harness.d.ts",
      "default": "./dist/extract/sources/use-state/harness.js"
    }
  },
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "architecture": "depcruise --config tools/depcruise.config.cjs src",
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "ci:examples": "tsx tools/examples-ci.ts",
    "demo": "vitest run test/modality/demo-acceptance.test.ts",
    "fix": "biome lint --write . && biome format --write .",
    "phase7": "tsx tools/phase7-differential.ts",
    "publish:npm": "npm publish --access public",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^24.10.1",
    "dependency-cruiser": "^17.4.3",
    "tsx": "^4.20.6",
    "vitest": "^4.0.14"
  }
}
