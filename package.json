{
  "name": "modality-ts",
  "version": "0.0.3",
  "description": "Model-checking-based testing tools for React state-transition bugs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harineko0/modality-ts.git"
  },
  "type": "module",
  "types": "./dist/modality/cli.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "modality": "dist/modality/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/modality/cli.d.ts",
      "default": "./dist/modality/cli.js"
    },
    "./check": {
      "types": "./dist/modality/check.d.ts",
      "default": "./dist/modality/check.js"
    },
    "./ci": {
      "types": "./dist/modality/ci.d.ts",
      "default": "./dist/modality/ci.js"
    },
    "./conform": {
      "types": "./dist/modality/conform.d.ts",
      "default": "./dist/modality/conform.js"
    },
    "./extract": {
      "types": "./dist/modality/extract.d.ts",
      "default": "./dist/modality/extract.js"
    },
    "./replay": {
      "types": "./dist/modality/replay.d.ts",
      "default": "./dist/modality/replay.js"
    },
    "./export-tla": {
      "types": "./dist/modality/export-tla.d.ts",
      "default": "./dist/modality/export-tla.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "default": "./dist/kernel/index.js"
    },
    "./kernel/props": {
      "types": "./dist/kernel/props/index.d.ts",
      "default": "./dist/kernel/props/index.js"
    },
    "./checker": {
      "types": "./dist/checker/index.d.ts",
      "default": "./dist/checker/index.js"
    },
    "./extraction": {
      "types": "./dist/extraction/index.d.ts",
      "default": "./dist/extraction/index.js"
    },
    "./extraction/pipeline": {
      "types": "./dist/extraction/pipeline/index.d.ts",
      "default": "./dist/extraction/pipeline/index.js"
    },
    "./extraction/spi": {
      "types": "./dist/extraction/spi/index.d.ts",
      "default": "./dist/extraction/spi/index.js"
    },
    "./harness": {
      "types": "./dist/harness/index.d.ts",
      "default": "./dist/harness/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./source-jotai": {
      "types": "./dist/sources/jotai/index.d.ts",
      "default": "./dist/sources/jotai/index.js"
    },
    "./source-jotai/harness": {
      "types": "./dist/sources/jotai/harness.d.ts",
      "default": "./dist/sources/jotai/harness.js"
    },
    "./source-router": {
      "types": "./dist/sources/router/index.d.ts",
      "default": "./dist/sources/router/index.js"
    },
    "./source-router/harness": {
      "types": "./dist/sources/router/harness.d.ts",
      "default": "./dist/sources/router/harness.js"
    },
    "./source-swr": {
      "types": "./dist/sources/swr/index.d.ts",
      "default": "./dist/sources/swr/index.js"
    },
    "./source-swr/harness": {
      "types": "./dist/sources/swr/harness.d.ts",
      "default": "./dist/sources/swr/harness.js"
    },
    "./source-use-state": {
      "types": "./dist/sources/use-state/index.d.ts",
      "default": "./dist/sources/use-state/index.js"
    },
    "./source-use-state/harness": {
      "types": "./dist/sources/use-state/harness.d.ts",
      "default": "./dist/sources/use-state/harness.js"
    }
  },
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "architecture": "depcruise --config tools/depcruise.config.cjs src",
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "ci:examples": "tsx tools/examples-ci.ts",
    "demo": "vitest run test/modality/demo-acceptance.test.ts",
    "phase7": "tsx tools/phase7-differential.ts",
    "publish:npm": "npm publish --access public",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dependency-cruiser": "^17.4.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.6",
    "vitest": "^4.0.14"
  }
}
