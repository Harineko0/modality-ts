  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "architecture": "depcruise --config tools/depcruise.config.cjs src",
    "build:rust": "node tools/build-rust-native.mjs",
    "build": "pnpm build:rust && tsc -b",
    "clean": "rm -rf dist native tsconfig.tsbuildinfo && cargo clean --manifest-path crates/checker/Cargo.toml",
    "ci:canaries": "tsx tools/canary-ci.ts",
    "ci:conformance": "tsx tools/conformance-ci.ts",
    "ci:examples": "tsx tools/examples-ci.ts",
    "benchmarks": "tsx tools/benchmark-ci.ts",
    "benchmarks:react-router": "tsx tools/benchmark-ci.ts --id ledgerops-react-router",
    "benchmarks:nextjs": "tsx tools/benchmark-ci.ts --id ledgerops-nextjs",
    "demo": "vitest run test/modality/demo-acceptance.test.ts",
    "docs:build": "pnpm --dir docs build",
    "docs:start": "pnpm --dir docs start",
    "fix": "biome lint --write . && biome format --write .",
    "phase7": "tsx tools/phase7-differential.ts",
    "perf:check": "tsx tools/check-performance-benchmark.ts",
    "publish:npm": "npm publish --provenance --access public",
    "test": "pnpm build:rust && vitest --exclude \"test/benchmarks/**\"",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "cli-truncate": "^6.0.0",
    "jsdom": "^29.1.1",
    "listr2": "^10.2.1",
    "log-update": "^8.0.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^24.10.1",
    "arktype": "^2.2.1",
    "dependency-cruiser": "^17.4.3",
    "strip-ansi": "^7.2.0",
    "tsx": "^4.20.6",
    "vitest": "^4.0.14",
    "zod": "^4.4.3"
  },
  "napi": {
    "name": "modality-checker",
    "triples": {
      "defaults": true,
      "additional": []
    }
  }
