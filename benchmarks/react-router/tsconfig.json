{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "modality-ts/core": ["../../src/core/index.ts"],
      "modality-ts/properties": ["../../src/core/props/index.ts"],
      "modality-ts/vars": ["../../src/core/props/vars.ts"]
    }
  },
  "include": ["src"]
}
